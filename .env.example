# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — it will NOT be committed to the repository.
#
# NEVER paste a real token directly into code, a commit, or a chat message.
# Always set it as an environment variable or store it in .env (gitignored).

# HuggingFace token — required to access gated datasets such as udell-lab/NLP4LP.
# Get your token at: https://huggingface.co/settings/tokens
# Choose a read-only token; a write token is only needed if you publish to HF Hub.
HF_TOKEN=your_hf_token_here

# ── Telemetry (optional) ──────────────────────────────────────────────────────
# When both variables below are set, every search query and its results are
# pushed to the specified private GitHub repository for training purposes.
# No personally identifiable information (IP, browser info, etc.) is collected —
# only the query text, top-k setting, and matched problem IDs/scores.
# Leave blank (or unset) to disable telemetry completely.
#
# TELEMETRY_REPO: "owner/repo" of the PRIVATE GitHub repository that will store
#                 the data, e.g. "SoroushVahidi/opt-agent-telemetry".
#                 The repo must already exist before running the app.
TELEMETRY_REPO=

# TELEMETRY_TOKEN: A GitHub personal-access-token (classic) with "repo" scope on
#                  TELEMETRY_REPO, OR a fine-grained token with
#                  "Contents: Read & write" permission on that specific repository.
#                  Get a token at: https://github.com/settings/tokens
TELEMETRY_TOKEN=
